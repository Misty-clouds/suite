# ─── Server ───────────────────────────────────────────────────────────────────
# 5050 by default — port 5000 collides with macOS AirPlay Receiver / Control Center.
PORT=5050
NODE_ENV=development

# ─── Database (MongoDB) ───────────────────────────────────────────────────────
# Local dev:        mongodb://localhost:27017/suite
# Docker Compose:   mongodb://mongo:27017/suite
# MongoDB Atlas:    mongodb+srv://<user>:<pass>@<cluster>/suite?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/suite

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose host: redis   |   Local dev host: localhost
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Use long, random, DISTINCT secrets in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
